# ── LLM providers (at least one required) ──────────────────────────────────
GOOGLE_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vexis:vexis@localhost:5432/vexis

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── GitHub OAuth (Section 1 — required for login) ───────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── JWT / Session ────────────────────────────────────────────────────────────
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_with_secrets_token_hex_32
JWT_EXPIRE_MINUTES=10080

# ── MinIO (object storage — used for code snapshots & artifacts) ─────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=vexis
# REQUIRED — set a strong random password, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
MINIO_SECRET_KEY=CHANGE_ME_strong_random_password

# ── Scan limits ──────────────────────────────────────────────────────────────
VEXIS_LOG_LEVEL=INFO
VEXIS_MAX_LLM_CALLS_PER_SCAN=100
VEXIS_SCAN_TIMEOUT_SECONDS=600

# ── Celery async scanning (opt-in) ───────────────────────────────────────────
# VEXIS_USE_CELERY=true
